{{ attach_library('custom_theme/swiper') }}
<section class="happy-customers">
  <div class="container">
    <div class="happy-customers__header">
      <h2 class="happy-customers__title">{{ title|default('OUR HAPPY CUSTOMERS') }}</h2>
      <div class="happy-customers__navigation">
        <button class="happy-customers__nav-btn happy-customers__nav-btn--prev">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 5L4 12L11 19M4 12H20" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="happy-customers__nav-btn happy-customers__nav-btn--next">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M13 5L20 12L13 19M20 12H4" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="swiper happy-customers__slider">
      <div class="swiper-wrapper">
        {% for review in testimonials %}
          <div class="swiper-slide">
            <div class="testimonial-card">
              <div class="testimonial-card__rating">
                {% for i in 1..5 %}
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M11 1.5L13.9 7.4L20.5 8.3L15.7 13L16.9 19.5L11 16.5L5.1 19.5L6.3 13L1.5 8.3L8.1 7.4L11 1.5Z" 
                      fill="{{ i <= review.rating ? '#FFC633' : '#E0E0E0' }}" />
                  </svg>
                {% endfor %}
              </div>
              <div class="testimonial-card__author">
                <span class="testimonial-card__name">{{ review.name }}</span>
                {% if review.verified %}
                  <div class="testimonial-card__verified">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="12" cy="12" r="12" fill="#01AB31"/>
                      <path d="M7 12L10.5 15.5L17 9" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                {% endif %}
              </div>
              <p class="testimonial-card__text">"{{ review.text }}"</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

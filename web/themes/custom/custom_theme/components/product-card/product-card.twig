<div class="product-card">
  <div class="product-card__image-wrapper">
    <a href="{{ url }}">
      <img src="{{ image_url }}" alt="{{ title }}" class="product-card__image">
    </a>
  </div>
  
  <div class="product-card__content">
    <h3 class="product-card__title">
      <a href="{{ url }}">{{ title }}</a>
    </h3>
    
    <div class="product-card__rating">
      <div class="product-card__rating-stars" aria-label="Rating: {{ rating }} out of 5">
        {% for i in 1..5 %}
          {% if rating >= i %}
            <svg width="19" height="19" viewBox="0 0 19 19" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9.42211 0L12.3364 5.90564L18.8442 6.8524L14.1332 11.444L15.2443 17.9317L9.42211 14.8693L3.60002 17.9317L4.71113 11.444L0 6.8524L6.50787 5.90564L9.42211 0Z" fill="#FFC633"/></svg>
          {% elseif rating > (i - 1) and rating < i %}
            <svg width="19" height="19" viewBox="0 0 19 19" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9.42211 0L12.3364 5.90564L18.8442 6.8524L14.1332 11.444L15.2443 17.9317L9.42211 14.8693L3.60002 17.9317L4.71113 11.444L0 6.8524L6.50787 5.90564L9.42211 0Z" fill="url(#half_fill_{{ i }})" /><defs><linearGradient id="half_fill_{{ i }}" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="50%" stop-color="#FFC633"/><stop offset="50%" stop-color="#e0e0e0"/></linearGradient></defs></svg>
          {% else %}
            <svg width="19" height="19" viewBox="0 0 19 19" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9.42211 0L12.3364 5.90564L18.8442 6.8524L14.1332 11.444L15.2443 17.9317L9.42211 14.8693L3.60002 17.9317L4.71113 11.444L0 6.8524L6.50787 5.90564L9.42211 0Z" fill="#e0e0e0"/></svg>
          {% endif %}
        {% endfor %}
      </div>
      <span class="product-card__rating-value">{{ rating }}/5</span>
    </div>
    
    <div class="product-card__price-row">
      <span class="product-card__price">${{ price }}</span>
      {% if original_price %}
        <span class="product-card__price-original">${{ original_price }}</span>
        {% set discount_calc = ((original_price - price) / original_price * 100)|round %}
        <span class="product-card__discount-badge">-{{ discount_calc }}%</span>
      {% endif %}
    </div>
  </div>
</div>

{# Main Layout Template #}
<div class="layout-container">

  {# Render the Top Header region (contains the dynamic Announcement Bar) #}
  {% if page.top_header %}
    <div class="region-top-header">
      {{ page.top_header }}
    </div>
  {% endif %}

  {{ attach_library('custom_theme/header') }}
  {% embed 'custom_theme:header' with {
    logo_text: 'SHOP.CO',
    search_placeholder: 'Search for products...'
  } only %}
    {% block navigation %}
      {{ page.header }}
    {% endblock %}
  {% endembed %}

  <main role="main">
    <div class="container admin-controls">
      {{ page.breadcrumb }}
      {{ page.highlighted }}
      {{ page.help }}
      {{ page.messages }}
      {{ page.tabs }}
    </div>

    {{ page.content }}
    {% if page.newsletter %}
      <div class="newsletter-region">
        {{ page.newsletter }}
      </div>
    {% endif %}
  </main>

  {% if page.footer_col_1 or page.footer_col_2 or page.footer_col_3 or page.footer_col_4 %}
    {{ attach_library('custom_theme/footer') }}
    {% embed 'custom_theme:footer' with {
      company_description: "We have clothes that suits your style and which you're proud to wear. From women to men."
    } %}
      {% block footer_company %}{{ page.footer_col_1 }}{% endblock %}
      {% block footer_help %}{{ page.footer_col_2 }}{% endblock %}
      {% block footer_faq %}{{ page.footer_col_3 }}{% endblock %}
      {% block footer_resources %}{{ page.footer_col_4 }}{% endblock %}
    {% endembed %}
  {% endif %}

  {% if page.footer %}
    <footer class="footer-admin-region" role="contentinfo">
      {{ page.footer }}
    </footer>
  {% endif %}

</div>

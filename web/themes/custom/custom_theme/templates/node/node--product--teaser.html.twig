{#
/**
 * @file
 * Theme override for a product node in teaser view mode.
 */
#}
{% set image_url = file_url(node.field_product_image.entity.field_media_image.entity.uri.value) %}
{% set product_url = url('entity.node.canonical', {'node': node.id()}) %}

{% include 'custom_theme:product-card' with {
  title: node.label,
  url: product_url,
  image_url: image_url,
  rating: node.field_product_rating.value,
  price: node.field_product_price.value,
  original_price: node.field_product_original_price.value
} only %}

<?php

/**
 * @file
 * Primary module hooks for UI Builder module.
 */

/**
 * Implements hook_theme().
 */
function ui_builder_theme($existing, $type, $theme, $path) {
  return [
    'field__ui_builder_clean' => [
      'render element' => 'element',
      'template' => 'field--ui-builder-clean',
      'base hook' => 'field',
    ],
    'block__ui_builder_clean' => [
      'render element' => 'elements',
      'template' => 'block--ui-builder-clean',
      'base hook' => 'block',
    ],
    'ui_builder_json_formatter' => [
      'render element' => 'element',
      'template' => 'ui-builder-json-formatter',
    ],
  ];
}

/**
 * Implements hook_theme_suggestions_field_alter().
 */
function ui_builder_theme_suggestions_field_alter(array &$suggestions, array $variables) {
  if (isset($variables['element']['#field_type']) && $variables['element']['#field_type'] === 'ui_builder_json') {
    // Add our highly specific suggestion to the end so it takes priority.
    $suggestions[] = 'field__ui_builder_clean';
  }
}

/**
 * Implements hook_theme_suggestions_block_alter().
 */
function ui_builder_theme_suggestions_block_alter(array &$suggestions, array $variables) {
  // Check if the block contains our ui_builder_json field.
  // Layout Builder puts the field render array inside 'content'.
  if (isset($variables['elements']['content']['#field_type']) && $variables['elements']['content']['#field_type'] === 'ui_builder_json') {
    // Add our highly specific block suggestion to strip the block wrappers.
    $suggestions[] = 'block__ui_builder_clean';
  }
}

/**
 * Implements hook_form_BASE_FORM_ID_alter() for node forms.
 *
 * When a content type has a ui_builder_json field, we take over the form:
 * - Hide body, tags, image, and other standard fields
 * - Hide revision, authoring, URL alias, and comment settings
 * - Hide Drupal's native form-actions (Save/Preview/Delete)
 * - Add a CSS class for targeted styling
 *
 * This mirrors Acquia Site Studio's behavior: only the title field
 * and the Layout Canvas builder are visible on the node edit form.
 */
function ui_builder_form_node_form_alter(array &$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id) {
  /** @var \Drupal\node\NodeInterface $node */
  $node = $form_state->getFormObject()->getEntity();
  $bundle = $node->bundle();

  // Check if this content type has a ui_builder_json field.
  $field_definitions = \Drupal::service('entity_field.manager')
    ->getFieldDefinitions('node', $bundle);

  $has_ui_builder = FALSE;
  foreach ($field_definitions as $field_name => $definition) {
    if ($definition->getType() === 'ui_builder_json') {
      $has_ui_builder = TRUE;
      break;
    }
  }

  if (!$has_ui_builder) {
    return;
  }

  // Add CSS class so our stylesheet can target this form.
  $form['#attributes']['class'][] = 'ui-builder-node-form';

  // Hide standard content fields — Site Studio style takeover.
  $fields_to_hide = [
    'body',
    'field_tags',
    'field_image',
    'field_metatag',
  ];
  foreach ($fields_to_hide as $field_name) {
    if (isset($form[$field_name])) {
      $form[$field_name]['#access'] = FALSE;
    }
  }

  // Hide sidebar/advanced sections.
  /* Removed based on user request to keep native sidebar cards */
  // $sections_to_hide = [
  //   'revision_information',
  //   'path',
  //   'author',
  //   'options',
  //   'comment',
  //   'menu',
  // ];
  // foreach ($sections_to_hide as $section) {
  //   if (isset($form[$section])) {
  //     $form[$section]['#access'] = FALSE;
  //   }
  // }

  // Hide Drupal's form actions — the React builder handles saving.
  //   $form['actions']['#access'] = FALSE;
  // }
}

/**
 * Implements hook_page_attachments().
 */
function ui_builder_page_attachments(array &$attachments) {
  // Only attach styles on frontend routes (non-admin).
  if (!\Drupal::service('router.admin_context')->isAdminRoute()) {
    $attachments['#attached']['library'][] = 'ui_builder/frontend_defaults';
  }
}

/**
 * Implements hook_library_info_alter().
 */
function ui_builder_library_info_alter(&$libraries, $extension) {
  if ($extension === 'ui_builder' && isset($libraries['frontend_defaults'])) {
    // Set a very high weight to ensure it loads after theme CSS.
    // CSS_AGGREGATE_THEME is usually 100, so 1000 is very safe.
    if (isset($libraries['frontend_defaults']['css']['theme'])) {
      foreach ($libraries['frontend_defaults']['css']['theme'] as $path => $options) {
        $libraries['frontend_defaults']['css']['theme'][$path]['weight'] = 1000;
      }
    }
  }
}

